<?xml version="1.0"?>
<extension key="caseenddate" type="module">
  <file>caseenddate</file>
  <name>Case End Date</name>
  <description>Allows easy display and editing of case end date in "manage case" form.</description>
  <license>GPL-3.0</license>
  <maintainer>
    <author>Allen Shaw</author>
    <email>allen@JoineryHQ.com</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://github.com/twomice/civicrm-caseenddate</url>
    <url desc="Documentation">https://twomice.github.io/civicrm-caseenddate/</url>
    <url desc="Support">https://github.com/twomice/civicrm-caseenddate/issues</url>
    <url desc="Licensing">http://www.gnu.org/licenses/gpl-3.0.html</url>
  </urls>
  <releaseDate>2024-04-01</releaseDate>
  <version>1.2.1</version>
  <develStage>beta</develStage>
  <compatibility>
    <ver>5.70</ver>
  </compatibility>
  <comments>Developed for Korlon by Joinery</comments>
  <civix>
    <namespace>CRM/Caseenddate</namespace>
    <format>25.10.2</format>
  </civix>
  <classloader>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <mixins>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
</extension>
